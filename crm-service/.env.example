# Скопируйте как .env и заполните.

# Neon: строка подключения. Можно тот же DATABASE_URL, что у бота, либо ОТДЕЛЬНУЮ
# read-only роль crm_reader (см. migrations/002_crm_role.sql).
CRM_DB_URL=postgresql://neondb_owner:ПАРОЛЬ@ep-xxx-pooler.neon.tech/neondb?sslmode=require

# Токен MAX-бота (тот же, что у основного бота) — им шлём сообщения пользователям.
MAX_BOT_TOKEN=

# Базовый адрес MAX Bot API (при 401/404 попробуйте https://platform-api2.max.ru).
# MAX_API_BASE=https://botapi.max.ru
# Если API принимает токен только query-параметром access_token:
# MAX_AUTH_QUERY=1

# JWT
JWT_SECRET=смените_на_длинную_случайную_строку
JWT_TTL_HOURS=12

# Учётные данные специалиста CRM (MVP)
CRM_LOGIN_EMAIL=admin@medinternet.ru
CRM_LOGIN_PASSWORD=

# Троттлинг рассылки (сообщений/сек; лимит MAX ~30/сек)
SEND_RATE_PER_SEC=25

# Порт API (Railway задаёт PORT сам)
API_PORT=8090
