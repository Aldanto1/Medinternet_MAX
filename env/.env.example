# Скопируйте этот файл как .env и заполните значения:
#   cp .env.example .env

# --- MAX Bot ---
# Токен бота из кабинета MAX:
#   Чат-боты → Перейти → Расширенные настройки → Настроить → поле «Токен»
BOT_TOKEN=

# Имя бота в MAX (без @). Нужно для ссылок max.ru/<BOT_NAME>?startapp=...
# Если не заполнить — попробуем взять из /me при старте.
BOT_NAME=

# Базовый адрес MAX Bot API. По умолчанию https://botapi.max.ru.
# Если API отвечает 401/404 — попробуйте https://platform-api2.max.ru
# MAX_API_BASE=https://botapi.max.ru

# Если ваша версия API принимает токен только query-параметром access_token
# (а не заголовком Authorization) — раскомментируйте:
# MAX_AUTH_QUERY=1

# --- База данных Neon / PostgreSQL (Connection String из дашборда Neon) ---
DATABASE_URL=

# --- Mini App ---
# Публичный HTTPS-адрес mini app (напр. ссылка от cloudflared-туннеля).
# Меняется при каждом перезапуске быстрого туннеля — обновляйте здесь.
WEBAPP_URL=

# Порт локального веб-сервера mini app (по умолчанию 8080)
WEBAPP_PORT=8080

# Аварийный обход проверки подписи initData (ТОЛЬКО для локальной отладки!)
# SKIP_INITDATA_CHECK=1

# --- API сервера Medinternet ---
API_SERVER_URL=
API_SERVER_KEY=

# --- Нейросеть RX Code AI (медицинский поисковик в mini app) ---
# NEURO_API_URL — базовый адрес API БЕЗ /api в конце (код сам добавит /api/chats)
# Ключ передаётся заголовком X-API-Key. Канал по умолчанию michat.
NEURO_API_URL=https://qa.rxcode.pro
NEURO_API_KEY=
# NEURO_CHANNEL=michat   # менять не нужно
